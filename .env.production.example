# ── Bootstrap (required) ──────────────────────────────────────────
# These are the only env vars needed by web / worker / agent-runtime.
DATABASE_URL=postgres://postgres:postgres@postgres:5432/knowledge_assistant
AUTH_SECRET=change-me
SUPER_ADMIN_USERNAMES=

# ── Initial seed & parser (consumed by upgrade / parser services) ─
# The upgrade service seeds these into system_settings on first run.
# After that, manage them via /settings; changes take effect on restart.
# The parser service (Python) still reads S3_* directly from env.
APP_URL=http://localhost:3000
AGENT_RUNTIME_URL=http://agent-runtime:4001
PARSER_SERVICE_URL=http://parser:8001
REDIS_URL=redis://redis:6379
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=knowledge_chunks
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=knowledge-assistant
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
ANTHROPIC_API_KEY=
