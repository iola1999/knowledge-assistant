{
  "name": "law-doc",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:web": "pnpm --filter @law-doc/web dev",
    "dev:worker": "pnpm --filter @law-doc/worker dev",
    "dev:agent": "pnpm --filter @law-doc/agent-runtime dev",
    "typecheck": "pnpm -r --if-present typecheck",
    "db:generate": "pnpm --filter @law-doc/db drizzle-kit generate",
    "db:migrate": "pnpm --filter @law-doc/db drizzle-kit migrate"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
